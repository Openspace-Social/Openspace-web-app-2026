{
  "expo": {
    "name": "Openspace.Social",
    "slug": "openspace-social",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "openspacesocial",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:openspace.social",
        "applinks:staging.openspace.social"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Openspace.Social needs access to your photos so you can upload avatar and cover photos for your profile.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.767950302419-sujekkd6pcq8lhnc5sqd5leohjt8hav8",
              "openspacesocial"
            ]
          }
        ]
      },
      "bundleIdentifier": "com.mem1984.openspacesocial",
      "buildNumber": "3"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C5CE7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.mem1984.openspacesocial",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "openspace.social",
              "pathPrefix": "/reset-password/"
            },
            {
              "scheme": "https",
              "host": "staging.openspace.social",
              "pathPrefix": "/reset-password/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Openspace.Social needs access to your photos so you can upload avatar and cover photos for your profile."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.767950302419-sujekkd6pcq8lhnc5sqd5leohjt8hav8"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9b3af6b5-b5c6-4f77-bb85-55b4f8c7e6f7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b3af6b5-b5c6-4f77-bb85-55b4f8c7e6f7"
    }
  }
}
